<?xml version="1.0"?>
<robot name="realistic_panda_style">

  <!-- ================= MATERIALS ================= -->
  <material name="panda_white">
    <color rgba="0.95 0.95 0.95 1"/>
  </material>

  <material name="panda_black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <!-- ================= BASE ================= -->
  <link name="panda_link0">
    <visual>
      <geometry>
        <cylinder length="0.25" radius="0.2"/>
      </geometry>
      <material name="panda_white"/>
    </visual>
  </link>

  <!-- ================= LINK 1 ================= -->
  <link name="panda_link1">
    <visual>
      <geometry>
        <cylinder length="0.333" radius="0.08"/>
      </geometry>
      <material name="panda_black"/>
    </visual>
  </link>

  <joint name="panda_joint1" type="revolute">
    <parent link="panda_link0"/>
    <child link="panda_link1"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 2 ================= -->
  <link name="panda_link2">
    <visual>
      <geometry>
        <cylinder length="0.316" radius="0.07"/>
      </geometry>
      <material name="panda_white"/>
    </visual>
  </link>

  <joint name="panda_joint2" type="revolute">
    <parent link="panda_link1"/>
    <child link="panda_link2"/>
    <origin xyz="0 0 0.333" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 3 ================= -->
  <link name="panda_link3">
    <visual>
      <geometry>
        <cylinder length="0.384" radius="0.065"/>
      </geometry>
      <material name="panda_black"/>
    </visual>
  </link>

  <joint name="panda_joint3" type="revolute">
    <parent link="panda_link2"/>
    <child link="panda_link3"/>
    <origin xyz="0 0 0.316" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.9" upper="2.9" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 4 ================= -->
  <link name="panda_link4">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.06"/>
      </geometry>
      <material name="panda_white"/>
    </visual>
  </link>

  <joint name="panda_joint4" type="revolute">
    <parent link="panda_link3"/>
    <child link="panda_link4"/>
    <origin xyz="0 0 0.384" rpy="1.5708 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0" upper="3.0" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 5 ================= -->
  <link name="panda_link5">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.05"/>
      </geometry>
      <material name="panda_black"/>
    </visual>
  </link>

  <joint name="panda_joint5" type="revolute">
    <parent link="panda_link4"/>
    <child link="panda_link5"/>
    <origin xyz="0 0 0.2" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.9" upper="2.9" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 6 ================= -->
  <link name="panda_link6">
    <visual>
      <geometry>
        <cylinder length="0.15" radius="0.045"/>
      </geometry>
      <material name="panda_white"/>
    </visual>
  </link>

  <joint name="panda_joint6" type="revolute">
    <parent link="panda_link5"/>
    <child link="panda_link6"/>
    <origin xyz="0 0 0.2" rpy="1.5708 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.1" upper="3.7" effort="50" velocity="2"/>
  </joint>

  <!-- ================= LINK 7 ================= -->
  <link name="panda_link7">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.04"/>
      </geometry>
      <material name="panda_black"/>
    </visual>
  </link>

  <joint name="panda_joint7" type="revolute">
    <parent link="panda_link6"/>
    <child link="panda_link7"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="50" velocity="2"/>
  </joint>

  <!-- ================= END EFFECTOR ================= -->
  <link name="panda_hand">
    <visual>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="panda_white"/>
    </visual>
  </link>

  <joint name="panda_hand_joint" type="fixed">
    <parent link="panda_link7"/>
    <child link="panda_hand"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

</robot>