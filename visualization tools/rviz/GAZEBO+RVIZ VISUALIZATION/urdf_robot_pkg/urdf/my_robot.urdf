<?xml version="1.0"?>
<robot name="simple_car">

  <!-- ================= MATERIALS ================= -->
  <material name="car_blue"><color rgba="0.1 0.3 0.8 1"/></material>
  <material name="wheel_black"><color rgba="0.05 0.05 0.05 1"/></material>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry><box size="1.2 0.6 0.3"/></geometry>
      <origin xyz="0 0 0.15"/>
      <material name="car_blue"/>
    </visual>
    <collision>
      <geometry><box size="1.2 0.6 0.3"/></geometry>
      <origin xyz="0 0 0.15"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0.15"/>
      <inertia ixx="1.0" iyy="1.0" izz="1.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= WHEEL TEMPLATE ================= -->
  <!-- FRONT LEFT -->
  <link name="front_left_wheel">
    <visual>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.4 0.35 0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- FRONT RIGHT -->
  <link name="front_right_wheel">
    <visual>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.4 -0.35 0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- REAR LEFT -->
  <link name="rear_left_wheel">
    <visual>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.4 0.35 0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- REAR RIGHT -->
  <link name="rear_right_wheel">
    <visual>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.4 -0.35 0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= GAZEBO PLUGINS ================= -->

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>0.7</wheel_separation>
      <wheel_diameter>0.24</wheel_diameter>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
    </plugin>
  </gazebo>
  
  <!-- ================= GAZEBO COLORS ================= -->

<gazebo reference="base_link">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="front_left_wheel">
  <material>Gazebo/Black</material>
</gazebo>

<gazebo reference="front_right_wheel">
  <material>Gazebo/Black</material>
</gazebo>

<gazebo reference="rear_left_wheel">
  <material>Gazebo/Black</material>
</gazebo>

<gazebo reference="rear_right_wheel">
  <material>Gazebo/Black</material>
</gazebo>

</robot>
